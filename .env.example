# Copy to `src/.env` (Vite `envDir` is `./src` in this project).
#
# Evvnt API — same origin as `npm run dev` in the `evvnt` backend repo. No trailing slash.
# Default backend port from that project is 4000.
VITE_API_URL=https://evvnt-staging.up.railway.app

# Set to "true" to open /events without logging in (dev/demo). Set "false" or remove for production.
# VITE_DASHBOARD_PUBLIC=true
